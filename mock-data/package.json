{
  "name": "querylab-json-server",
  "version": "1.0.0",
  "description": "JSON Server para dados mock do QueryLab",
  "main": "server.js",
  "scripts": {
    "start": "json-server --watch db.json --port ${PORT:-3001} --host 0.0.0.0",
    "start:railway": "json-server --watch db.json --port $PORT --host 0.0.0.0",
    "dev": "json-server --watch db.json --port 3001"
  },
  "dependencies": {
    "json-server": "^0.17.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
