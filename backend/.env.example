# Configurações do Servidor
PORT=5000
FRONTEND_URL=http://localhost:3000

# Configurações do JSON Server
JSON_SERVER_URL=http://localhost:3001

# Configurações JWT
JWT_SECRET=querylab-secret-key-2024-change-in-production
JWT_EXPIRES_IN=7d

# Configurações LLM
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Configurações do Banco de Dados (Produção)
DB2_HOST=your_db2_host
DB2_PORT=50000
DB2_DATABASE=your_database
DB2_USERNAME=your_username
DB2_PASSWORD=your_password
