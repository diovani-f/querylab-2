# Configurações do Servidor
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Banco de Dados da Aplicação (autenticação, sessões, etc.)
DB_TYPE=postgres
POSTGRES_URL=postgresql://user:password@localhost:5432/querylab_app

# Banco de Dados para Consultas SQL (LLM) - Banco separado com dados do INEP
QUERY_DB_TYPE=postgres
QUERY_DB_HOST=localhost
QUERY_DB_PORT=5432
QUERY_DB_USER=your_username
QUERY_DB_PASSWORD=your_password
QUERY_DB_TYPE=your_database_name

# Configurações JWT
JWT_SECRET=querylab-secret-key-2024-change-in-production
JWT_EXPIRES_IN=7d

# Configurações LLM
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
