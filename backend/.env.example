# Configurações do Servidor
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Banco de Dados da Aplicação (autenticação, sessões, etc.)
DB_TYPE=json-server
JSON_SERVER_URL=http://localhost:3001

# Banco de Dados para Consultas SQL (LLM)
QUERY_DB_TYPE=db2-http

# DB2 Service (Microserviço)
DB2_SERVICE_URL=http://localhost:5001

# Configurações JWT
JWT_SECRET=querylab-secret-key-2024-change-in-production
JWT_EXPIRES_IN=7d

# Configurações LLM
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
