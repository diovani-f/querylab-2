{
  "name": "querylab",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "start": "npm run start --workspaces",
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\""
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/socket.io": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "socket.io": "^4.8.1"
  }
}
